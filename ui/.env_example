# Dev server port
# - Electron mode: defaults to 0 (random available port)
# - Web mode: defaults to 1515
# PORT=1515

# Default A2A Agent URL — injected at build time as __AGENT_URL__.
# Used as the fallback when the user has not stored a custom URL in
# localStorage ('agent_url').
# VITE_AGENT_URL=http://localhost:1112
