# Default: treat all files as text and normalize to LF in the repo
* text=auto eol=lf

# Windows-specific scripts must stay CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Unix shell scripts must stay LF
*.sh text eol=lf

# Common binary types — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
