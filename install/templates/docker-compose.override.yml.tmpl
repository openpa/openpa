# Dev-channel override. The installer emits this next to
# docker-compose.yml only when --channel=dev && --mode=docker; compose
# merges files in the same directory automatically, so production
# installs never see these overrides.
#
# - ``build.context`` points at the local checkout (the main compose
#   template's ``../..`` would resolve to ~/.openpa/.. and miss the
#   Dockerfile entirely).
# - ``OPENPA_PIP_SPEC=-e /src`` switches the image build from
#   ``pip install openpa==<ver>`` to an editable install rooted at the
#   bind-mounted checkout (see Dockerfile.desktop's --mount=type=bind).
# - The ``__REPO_ROOT__:/src`` runtime volume keeps the editable install
#   resolvable after the build step's bind mount is gone, and lets
#   host-side edits show up inside the container after a restart.
services:
  openpa:
    build:
      context: "__REPO_ROOT__"
      args:
        OPENPA_PIP_SPEC: "-e /src"
    volumes:
      - "__REPO_ROOT__:/src"
