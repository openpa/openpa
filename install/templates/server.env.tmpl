# OpenPA backend — server deployment.
# Generated by install.sh / install.ps1 with __APP_HOST__ replaced by the
# IP or domain you provided at install time.

# Server Configuration
ENV=production
HOST=0.0.0.0
PORT=1112
APP_URL=http://__APP_HOST__:1112
DEBUG=false
LOG_LEVEL=INFO
DISABLE_LOG=false

# CORS — allow both the public host and localhost so the UI works
# whether you open it locally or remotely.
CORS_ALLOWED_ORIGINS=http://__APP_HOST__:1515,http://localhost:1515

# Setup wizard preset
SETUP_WIZARD_ENV=server
