# OpenPA Docker bundle — runtime configuration.
#
# Generated by install.sh / install.ps1; values picked at install time
# end up here, and Compose substitutes them into docker-compose.yml.
#
# Treat this file like a credential store: VNC_PASSWORD is auto-
# generated to ~24 random characters at install time; Postgres
# credentials are added on demand by the Setup Wizard when the user
# picks Database = Postgres / Docker.

# ── Image / build ──────────────────────────────────────────────────────────
# Pin to a release tag once the image is published. Otherwise Compose
# falls back to ``build:`` and compiles locally from Dockerfile.desktop.
OPENPA_VERSION=__OPENPA_VERSION__

# ── App-level config ───────────────────────────────────────────────────────
# APP_URL is the canonical externally-reachable backend URL the agent
# advertises in its A2A agent card. CORS controls which UI origins the
# backend trusts. Both are filled by the installer based on the
# deployment-type answer (local vs server).
APP_URL=__APP_URL__
CORS_ALLOWED_ORIGINS=__CORS_ALLOWED_ORIGINS__
SETUP_WIZARD_ENV=__SETUP_WIZARD_ENV__

# How OpenPA itself was installed. Drives the Setup Wizard's per-service
# deployment-mode filter (see install_catalog.toml's [mode_rules]).
INSTALL_MODE=__INSTALL_MODE__

# ── Ports (host side) ──────────────────────────────────────────────────────
# Edit if a host port is already in use. The container-side ports are
# fixed; only the host mappings are configurable.
API_PORT=1112
SPA_PORT=1515
NOVNC_PORT=6080
VNC_PORT=5900

# ── Compose project ────────────────────────────────────────────────────────
# Pinned so ``docker compose`` invocations from the host and from
# inside the openpa container address the same project (and therefore
# the same named volumes). Default compose project naming uses the
# parent directory name, which would diverge between host (``docker``)
# and container (``openpa-compose``).
COMPOSE_PROJECT_NAME=openpa

# ── Service activation ─────────────────────────────────────────────────────
# Starts empty — the Setup Wizard appends entries as the user picks
# Docker-mode services. Possible values (comma-separated):
#   with-postgres   → postgres sibling container
#   with-qdrant     → qdrant sibling container
#   with-chroma     → chromadb sibling container
COMPOSE_PROFILES=

# ── Desktop ────────────────────────────────────────────────────────────────
# Set on first install; copied to your clipboard then. To rotate, edit
# this value and run ``docker compose up -d``.
VNC_PASSWORD=__VNC_PASSWORD__

# Higher resolutions cost more bandwidth and CPU; 1280x720 is the
# comfort default. Common choices: 1280x720, 1440x900, 1920x1080, 2560x1440.
RESOLUTION=1280x720
