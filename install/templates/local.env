# OpenPA backend — local (loopback) deployment.
# Generated by install.sh / install.ps1. Edit if you need to override anything.

# Server Configuration
ENV=local
HOST=127.0.0.1
PORT=1112
APP_URL=http://localhost:1112
DEBUG=true
LOG_LEVEL=INFO
DISABLE_LOG=false

# CORS — only the loopback UI origin
CORS_ALLOWED_ORIGINS=http://localhost:1515,http://127.0.0.1:1515

# Setup wizard preset
SETUP_WIZARD_ENV=local
