# OpenPA backend — custom deployment.
# Generated by install.sh / install.ps1 from the answers you gave to
# the "advanced" prompts. Edit if you need to tune anything afterwards.
#
# `custom` is intentionally permissive — it doesn't pick a HOST / APP_URL
# / CORS shape for you, the way `local` and `server` do. The defaults
# fit a containerized install (bind 0.0.0.0, browse from the docker
# host), but any of the four values below can be overridden via flags
# (--listen-host / --public-url / --allowed-origins / --wizard-preset)
# or by editing this file.

# Server Configuration
ENV=custom
HOST=__LISTEN_HOST__
PORT=1112
APP_URL=__PUBLIC_URL__
DEBUG=true
LOG_LEVEL=INFO
DISABLE_LOG=false

# CORS — origins allowed to call the API. The installer fills in the
# public URL plus the localhost SPA listener when the user leaves the
# prompt blank.
CORS_ALLOWED_ORIGINS=__CORS_ALLOWED_ORIGINS__

# Setup wizard preset
SETUP_WIZARD_ENV=__SETUP_WIZARD_ENV__
