# OpenPA backend — container deployment.
# Generated by install.sh / install.ps1 when the host running the
# installer is itself a Docker / Podman container, and the user will
# browse the wizard from the *docker host* via published ports.
#
# Binds 0.0.0.0 so docker -p forwards to the listeners; URLs use
# localhost because that's what the host browser sees once the ports
# are published.

# Server Configuration
ENV=container
HOST=0.0.0.0
PORT=1112
APP_URL=http://localhost:1112
DEBUG=true
LOG_LEVEL=INFO
DISABLE_LOG=false

# CORS — only the loopback UI origin (the host browser hits localhost:1515)
CORS_ALLOWED_ORIGINS=http://localhost:1515,http://127.0.0.1:1515

# Setup wizard preset
SETUP_WIZARD_ENV=local
